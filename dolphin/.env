# .env — Mario Kart Wii RL Project Config

# Required: path to your Mario Kart Wii game file
DOLPHIN_ISO_PATH='/Users/michaeldigiuseppe/Downloads/Mario Kart Wii (USA) (En,Fr,Es).rvz'

# Optional: Dolphin auto-detects on macOS, but set if it can't find it
# DOLPHIN_EXE_PATH=/Applications/Dolphin.app/Contents/MacOS/Dolphin

# Optional: defaults to ~/Library/Application Support/Dolphin
# DOLPHIN_USER_DIR=/Users/michaeldigiuseppe/Library/Application Support/Dolphin

# Optional: path to a savestate file for auto-loading on reset
# DOLPHIN_SAVESTATE=/Users/michaeldigiuseppe/Library/Application Support/Dolphin/StateSaves/RMCE01.s01

# Optional: "Null" = headless (default), "Metal" = visible window on Mac
DOLPHIN_GFX_BACKEND=Metal